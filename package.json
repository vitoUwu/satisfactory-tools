{
  "name": "satisfactory-tools",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.3.2",
      "@libsql/client": "0.17.4",
      "libsql": "0.5.29",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun --no-orphans run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "db:push": "bun run --filter @satisfactory-tools/db db:push",
    "db:studio": "bun run --filter @satisfactory-tools/db db:studio",
    "db:generate": "bun run --filter @satisfactory-tools/db db:generate",
    "db:migrate": "bun run --filter @satisfactory-tools/db db:migrate",
    "db:local": "bun run --filter @satisfactory-tools/db db:local",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@satisfactory-tools/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@satisfactory-tools/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.5"
}
